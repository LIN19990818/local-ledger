{
  "expo": {
    "name": "本地记账本",
    "slug": "local-ledger",
    "version": "1.0.5",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "local-ledger",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4F46E5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.localledger.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "使用 Face ID 解锁应用"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#4F46E5"
      },
      "package": "com.localledger.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-sqlite",
        {
          "enableFTS": true
        }
      ],
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow $(PRODUCT_NAME) to use Face ID."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "允许访问相册以上传账单凭证"
        }
      ],
      "expo-media-library"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
